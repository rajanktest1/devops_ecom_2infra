# ============================================================
# Terraform — CRITICAL: state files contain plaintext secrets
# ============================================================

# Local state files — these contain DB passwords, connection strings in plaintext
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output files — may contain sensitive variable values
*.tfplan
*.plan

# Terraform working directories generated by init
**/.terraform/
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files (local dev overrides — should never be committed)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# terraform.tfvars can contain secrets if used locally with sensitive values
# .tfvars files in environments/ only contain non-sensitive SKU/location values (safe to commit)
# Exclude any *secrets* or *local* tfvars files
*.secrets.tfvars
*.local.tfvars
secrets.tfvars
local.tfvars

# ============================================================
# Secrets & credentials — NEVER commit these
# ============================================================
.env
.env.*
*.env
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.secret
secrets/
credentials/
service-account*.json

# Azure credentials files
azure.conf
azure-credentials*
azureauth.json
.azure/

# ============================================================
# Bootstrap script output — storage account names printed locally
# ============================================================
bootstrap-output.txt
.bootstrap-state

# ============================================================
# Build artifacts (zip files — produced by App CI, not stored here)
# ============================================================
artifacts/
*.zip

# ============================================================
# OS noise
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/

# ============================================================
# Editor / IDE noise
# ============================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.project
.classpath
.settings/
.history/

# ============================================================
# Logs & temp
# ============================================================
logs/
*.log
tmp/
temp/
pids/
*.pid
*.seed
*.pid.lock

# ============================================================
# Misc
# ============================================================
.cache/
